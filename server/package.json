    "dotenv": "^17.4.2",
    "hono": "^4.6.14",
    "octokit": "^5.0.5",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/dockerode": "^4.0.1",
