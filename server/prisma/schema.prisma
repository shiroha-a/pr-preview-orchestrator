// Prisma schema for the PR preview orchestrator.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// A GitHub repository tracked by the orchestrator.
model Repository {
  id             String   @id @default(cuid())
  owner          String
  name           String
  // Optional: only set when accessed via a GitHub App installation (legacy).
  installationId Int?
  // Preview configuration for this repository.
  // Newline-separated compose file paths; later files override earlier ones (issue #52).
  composePath    String   @default("docker-compose.yml")
  webService     String?
  internalPort   Int?
  // File rewrite rules (JSON array) applied to the cloned repo before compose up.
  fileRewrites   String?
  // Overlay files (JSON array) written into the cloned repo before compose up.
  overlayFiles   String?
  // Reset Docker volumes on each (re)build to start from a clean state.
  resetVolumes   Boolean  @default(false)
  // Where images are built (issue #80): "auto" / "remote" / "local".
  // Null inherits the global default (BUILD_MODE_DEFAULT).
  buildMode      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pullRequests PullRequest[]
  previews     PreviewEnvironment[]
  profiles     SettingsProfile[]

  @@unique([owner, name])
}

/// A named settings profile overriding the repository defaults (issue #52).
/// Each nullable field inherits the repository default when null and replaces
/// it (field-level, no merging) when set.
model SettingsProfile {
  id           String   @id @default(cuid())
  repositoryId String
  name         String
  // Newline-separated compose file paths; later files override earlier ones.
  composePath  String?
  webService   String?
  internalPort Int?
  // File rewrite rules (JSON array).
  fileRewrites String?
  // Overlay files (JSON array).
  overlayFiles String?
  resetVolumes Boolean?
  // Where images are built (issue #80); null inherits the repository setting.
  buildMode    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository Repository           @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  previews   PreviewEnvironment[]

  @@unique([repositoryId, name])
}

/// A cached pull request fetched from GitHub.
model PullRequest {
  id           String   @id @default(cuid())
  repositoryId String
  number       Int
  title        String
  body         String?
  state        String // open / closed / merged
  draft        Boolean  @default(false)
  authorLogin  String
  headRef      String
  headSha      String
  baseRef      String
  htmlUrl      String?
  prUpdatedAt  DateTime
  // Labels (JSON array of { name, color }) and milestone title (issue #24).
  labels       String?
  milestone    String?
  // Cached diff / comments to reduce GitHub API calls (issue #10).
  diffCache     String?
  commentsCache String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository Repository          @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  preview    PreviewEnvironment?

  @@unique([repositoryId, number])
}

/// An ephemeral Docker-based preview environment targeting a pull request or a
/// branch of a repository (issue #25).
model PreviewEnvironment {
  id             String   @id @default(cuid())
  // Target kind: "pr" (pullRequestId set) or "branch" (repositoryId + branchRef set).
  kind           String   @default("pr")
  pullRequestId  String?  @unique
  repositoryId   String?
  branchRef      String?
  // idle / pending / cloning / building / running / stopping / stopped / failed
  status         String   @default("idle")
  composeProject String
  url            String?
  hostPort       Int?
  commitSha      String?
  logs           String   @default("")
  // Settings profile used for the last build; null = repository defaults (issue #52).
  profileId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pullRequest PullRequest?     @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  repository  Repository?      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  profile     SettingsProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@unique([repositoryId, branchRef])
}

/// A unit of asynchronous work processed by the in-process worker.
model Job {
  id        String   @id @default(cuid())
  type      String // build / stop / destroy / sync
  payload   String // JSON-encoded payload
  status    String   @default("queued") // queued / running / done / failed
  attempts  Int      @default(0)
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Auto-generated VAPID key pair for Web Push notifications (issue #77).
/// Created on first use; effectively a single row.
model WebPushKeys {
  id         String   @id @default(cuid())
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())
}

/// A browser push subscription receiving build-completion notifications (issue #77).
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

/// A registered external build agent (issue #80). Agents authenticate with a
/// bearer token (only its hash is stored) and pull build jobs from the
/// orchestrator, so they never need an inbound connection.
model BuildAgent {
  id         String    @id @default(cuid())
  name       String    @unique
  // SHA-256 hex of the agent's bearer token; the plaintext is shown only once.
  tokenHash  String    @unique
  // Updated on every poll; an agent is considered online while recent.
  lastSeenAt DateTime?
  enabled    Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

/// An admin user for Basic authentication.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
