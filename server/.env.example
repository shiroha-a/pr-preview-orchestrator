# Database (SQLite, local). Path is relative to the server/ directory.
DATABASE_URL="file:./dev.db"

# --- HTTP server ---
# API server port. Uses API_PORT (not the generic PORT) to avoid clashing with
# other tools that may export PORT in the shell environment.
API_PORT="8787"
# Allowed origin for CORS (the Vite dev server).
WEB_ORIGIN="http://localhost:5173"

# --- GitHub App ---
# Create a GitHub App (see README) and fill these in.
GITHUB_APP_ID=""
# Paste the full PEM private key. For multi-line values use \n escapes or quote
# the literal newlines. Example:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_PRIVATE_KEY=""
# Webhook secret configured on the GitHub App.
GITHUB_WEBHOOK_SECRET=""
# OAuth client id/secret (optional, only needed for user-facing OAuth flows).
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""

# --- Preview environments ---
# Directory where target repositories are cloned (relative to project root).
WORKSPACES_DIR="./workspaces"
# Hostname used to build preview URLs.
PREVIEW_HOST="localhost"
# Host port range allocated to preview environments.
PREVIEW_PORT_MIN="13000"
PREVIEW_PORT_MAX="13999"
