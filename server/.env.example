# Database (SQLite, local). Path is relative to the server/ directory.
DATABASE_URL="file:./dev.db"

# --- HTTP server ---
# API server port. Uses API_PORT (not the generic PORT) to avoid clashing with
# other tools that may export PORT in the shell environment.
API_PORT="8787"
# Allowed origin for CORS (the Vite dev server).
WEB_ORIGIN="http://localhost:5173"

# --- Admin access control ---
# Optional. Set both to require HTTP Basic auth for the admin UI and API.
# The health check and GitHub webhook endpoint are exempt.
ADMIN_USER=""
ADMIN_PASSWORD=""

# --- GitHub ---
# The orchestrator uses the public GitHub REST API.
# A token is OPTIONAL: public repositories work without it. Setting a Personal
# Access Token raises rate limits and enables private repository access.
GITHUB_TOKEN=""
# Optional webhook secret. Set the same value on the repository's webhook to
# enable PR event automation (auto rebuild on push, auto teardown on close).
GITHUB_WEBHOOK_SECRET=""

# --- Preview environments ---
# Directory where target repositories are cloned (relative to server/).
WORKSPACES_DIR="./workspaces"
# Hostname used to build local preview URLs (when tunnelling is disabled).
PREVIEW_HOST="localhost"
# Host port range allocated to preview environments.
PREVIEW_PORT_MIN="13000"
PREVIEW_PORT_MAX="13999"
# Expose previews via Cloudflare Quick Tunnel (trycloudflare.com).
# Set to "false" to disable and use local URLs instead. Requires `cloudflared`.
PREVIEW_TUNNEL="true"
# Idle timeout (ms) for build commands: abort only after this long with no output.
PREVIEW_BUILD_TIMEOUT_MS="600000"
# Docker image used as a throwaway helper to read/write preview volumes for
# export/import. Needs sh, tar, gzip, find and du.
PREVIEW_VOLUME_HELPER_IMAGE="busybox:stable"
